# --- 基础设施配置 (云服务器) ---
DB_USER=mikmok_user
DB_PASSWORD=your_strong_db_password
DB_NAME=mikmok

REDIS_PASSWORD=your_strong_redis_password

MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=your_strong_minio_password

# Docker 镜像代理 (可选，如 m.daocloud.io, dockerproxy.com 等)
# DOCKER_REGISTRY=docker.io

# --- 开发环境配置 (本地) ---
# 云服务器的公网 IP
SERVER_IP=1.2.3.4

# 后端连接配置 (Spring Boot 会读取这些变量)
SPRING_DATASOURCE_URL=jdbc:postgresql://${SERVER_IP}:5432/${DB_NAME}
SPRING_REDIS_HOST=${SERVER_IP}
SPRING_REDIS_PASSWORD=${REDIS_PASSWORD}
MINIO_ENDPOINT=http://${SERVER_IP}:9000
